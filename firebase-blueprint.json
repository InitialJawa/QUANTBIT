{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile containing balances and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "cash": { "type": "number" },
        "theme": { "type": "string" },
        "dataFeed": { "type": "string" },
        "activeConfig": { "type": "string" },
        "engineConfig": { "type": "object" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid"]
    },
    "WatchlistItem": {
      "title": "WatchlistItem",
      "description": "A ticker the user is watching",
      "type": "object",
      "properties": {
        "ticker": { "type": "string", "maxLength": 10 },
        "addedAt": { "type": "string" }
      },
      "required": ["ticker", "addedAt"]
    },
    "PortfolioItem": {
      "title": "PortfolioItem",
      "description": "Holding item in portfolio",
      "type": "object",
      "properties": {
        "ticker": { "type": "string", "maxLength": 10 },
        "shares": { "type": "number" },
        "buyPrice": { "type": "number" },
        "addedAt": { "type": "string" }
      },
      "required": ["ticker", "shares", "buyPrice", "addedAt"]
    },
    "TradeLog": {
      "title": "TradeLog",
      "description": "A transaction log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "ticker": { "type": "string", "maxLength": 10 },
        "shares": { "type": "number" },
        "price": { "type": "number" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "type", "ticker", "shares", "price", "timestamp"]
    },
    "CachedReport": {
      "title": "CachedReport",
      "description": "AI analysis for a ticker",
      "type": "object",
      "properties": {
        "ticker": { "type": "string", "maxLength": 10 },
        "data": { "type": "object" },
        "updatedAt": { "type": "string" }
      },
      "required": ["ticker", "data", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile document"
    },
    "users/{userId}/watchlist/{ticker}": {
      "schema": { "$ref": "#/entities/WatchlistItem" },
      "description": "User watchlist items"
    },
    "users/{userId}/portfolio/{ticker}": {
      "schema": { "$ref": "#/entities/PortfolioItem" },
      "description": "User portfolio holdings"
    },
    "users/{userId}/tradeLogs/{logId}": {
      "schema": { "$ref": "#/entities/TradeLog" },
      "description": "User transaction history"
    },
    "users/{userId}/cachedReports/{ticker}": {
      "schema": { "$ref": "#/entities/CachedReport" },
      "description": "User cached AI reports"
    }
  }
}
