{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "data/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/engine/force-sync",
      "schedule": "0 10 * * *"
    }
  ]
}
