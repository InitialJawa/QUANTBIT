{
  "name": "quantbit-terminal",
  "version": "1.0.0",
  "description": "Quantitative stock trading, backtesting, and portfolio management terminal for the Indonesia Stock Exchange (IDX).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "start cmd /c \"tsx server.ts\" && vite",
    "build:db": "tsx scripts/build-db.ts",
    "split-data": "tsx scripts/split-data.ts",
    "build": "npm run build:db && npm run split-data && vite build && tsx scripts/build-cf.ts",
    "start": "npx wrangler pages dev dist",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true });\"",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/engine/__tests__/*.test.ts src/ai/__tests__/*.test.ts src/hooks/__tests__/*.test.ts",
    "test:ui": "vitest run",
    "test:ui:watch": "vitest",
    "test:ui:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "serve-api": "tsx server.ts",
    "serve-mcp": "tsx src/mcp/index.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.10.1",
    "express": "^4.22.2",
    "groq-sdk": "^1.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^4.4.1",
    "nodemailer": "^9.0.1",
    "openai": "^6.42.0",
    "papaparse": "^5.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "yahoo-finance2": "^3.15.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/papaparse": "^5.5.2",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
