# Required: Gemini API Key for financial analysis and chat assistant.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Optional: Port configuration (default: 3000)
PORT=3000

# Optional: Fallback AI APIs
GROQ_API_KEY="YOUR_GROQ_API_KEY_HERE"
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY_HERE"

# Optional: Live stock prices API Key (GoAPI.id)
GOAPI_API_KEY="YOUR_GOAPI_API_KEY_HERE"

# Optional: Email notifications — configurasi untuk alert trading
#
# Dev (localhost): SMTP via nodemailer (server.ts)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER="your-email@gmail.com"
# EMAIL_PASS="your-gmail-app-password"   # Gmail: buat app password, bukan password biasa
# EMAIL_TO="recipient@example.com"        # default: EMAIL_USER
# EMAIL_FROM="your-email@gmail.com"
#
# Production (Cloudflare): Resend API — daftar gratis di https://resend.com
# RESEND_API_KEY="re_xxxxxxx"
# EMAIL_FROM="QuantBit <onboarding@resend.dev>"  # sampe verify domain pake @resend.dev
# EMAIL_TO="recipient@example.com"
